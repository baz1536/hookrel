{
  "name": "hookrel",
  "version": "1.2.1",
  "description": "Self-hosted webhook relay — receive webhooks, match rules, and dispatch notifications to email, Telegram, Pushover, and Microsoft 365.",
  "main": "src/server.js",
  "scripts": {
    "start": "node --env-file=.env src/server.js",
    "dev": "nodemon --env-file=.env src/server.js",
    "build:editor": "esbuild editor-src/tiptap-bundle.js --bundle --format=iife --outfile=public/js/tiptap.bundle.js --minify",
    "lint": "npm run lint:js && npm run lint:css && npm run lint:html",
    "lint:js": "eslint src public/js",
    "lint:css": "stylelint \"public/css/**/*.css\"",
    "lint:html": "htmlhint \"public/partials/**/*.html\" \"templates/**/*.html\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@azure/identity": "^4.13.1",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "connect-mongo": "^6.0.0",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "global-agent": "^4.1.3",
    "mongodb": "^7.2.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.6",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tiptap/core": "^3.22.4",
    "@tiptap/extension-blockquote": "^3.22.4",
    "@tiptap/extension-bold": "^3.22.4",
    "@tiptap/extension-bullet-list": "^3.22.4",
    "@tiptap/extension-color": "^3.22.4",
    "@tiptap/extension-document": "^3.22.4",
    "@tiptap/extension-hard-break": "^3.22.4",
    "@tiptap/extension-heading": "^3.22.4",
    "@tiptap/extension-highlight": "^3.22.4",
    "@tiptap/extension-history": "^3.22.4",
    "@tiptap/extension-horizontal-rule": "^3.22.4",
    "@tiptap/extension-image": "^3.22.4",
    "@tiptap/extension-italic": "^3.22.4",
    "@tiptap/extension-link": "^3.22.4",
    "@tiptap/extension-list-item": "^3.22.4",
    "@tiptap/extension-ordered-list": "^3.22.4",
    "@tiptap/extension-paragraph": "^3.22.4",
    "@tiptap/extension-strike": "^3.22.4",
    "@tiptap/extension-table": "^3.22.4",
    "@tiptap/extension-table-cell": "^3.22.4",
    "@tiptap/extension-table-header": "^3.22.4",
    "@tiptap/extension-table-row": "^3.22.4",
    "@tiptap/extension-text": "^3.22.4",
    "@tiptap/extension-text-style": "^3.22.4",
    "@tiptap/extension-underline": "^3.22.4",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "eslint-plugin-n": "^17.24.0",
    "htmlhint": "^1.9.2",
    "nodemon": "^3.1.14",
    "stylelint": "^17.9.0",
    "stylelint-config-standard": "^40.0.0"
  }
}
